{
  "name": "atlas00",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "deps:install": "pnpm install",
    "deps:patch": "node scripts/sync-piper-tts-codegen.js && node scripts/patch-react-native-voice.js && node scripts/patch-react-native-quick-sqlite.js",
    "deps:reset": "node scripts/reset-deps.js",
    "native:clean": "node scripts/clean-build.js",
    "native:regen": "node scripts/regen-native.js",
    "native:pods": "cd ios && PIPER_USE_ESPEAK=1 pod install",
    "native:rebuild": "node scripts/nuclear-rebuild.js",
    "rag:pack": "node scripts/sync-pack-small.js",
    "rag:pack:full": "node scripts/sync-pack-full.js",
    "rag:runtime:update": "node scripts/update-runtime.js",
    "verify:gates": "node scripts/validate-e2e-gates.js",
    "verify:gates:full-pack": "ALLOW_PACK_WITH_MODELS=1 node scripts/validate-e2e-gates.js",
    "start": "react-native start",
    "start:local": "dotenv -e .env.local -- react-native start",
    "start:local:reset": "dotenv -e .env.local -- react-native start --reset-cache",
    "android": "react-native run-android",
    "ios": "pnpm run native:pods && react-native run-ios",
    "icon": "pnpm react-native-bootsplash generate ./assets/icons/A-Icon.jpg --background=16242f --platforms=android,ios --assets-output=assets/bootsplash",
    "pack": "pnpm run rag:pack",
    "pack:full": "pnpm run rag:pack:full",
    "piper": "./scripts/download-piper-voice.sh",
    "ping-piper": "node scripts/ping-piper.js",
    "validate": "pnpm run verify:gates",
    "validate:full-pack": "pnpm run verify:gates:full-pack",
    "runtime:update": "pnpm run rag:runtime:update",
    "lint": "eslint .",
    "test": "jest",
    "postinstall": "pnpm run deps:patch",
    "storybook-generate": "sb-rn-get-stories",
    "storybook": "STORYBOOK_ENABLED=true react-native start",
    "storybook:reset": "STORYBOOK_ENABLED=true react-native start --reset-cache"
  },
  "dependencies": {
    "@gorhom/bottom-sheet": "^5.2.8",
    "@mtg/runtime": "file:../mtg_rules/runtime-ts",
    "@react-native-async-storage/async-storage": "^3.0.1",
    "@react-native-community/datetimepicker": "^9.0.0",
    "@react-native-community/slider": "^5.1.2",
    "@react-native-voice/voice": "^3.2.4",
    "@react-native/new-app-screen": "0.81.4",
    "@react-three/fiber": "^9.5.0",
    "@storybook/addon-ondevice-actions": "^10.2.3",
    "@storybook/addon-ondevice-controls": "^10.2.3",
    "@storybook/react-native": "^10.2.3",
    "babel-loader": "^8.4.1",
    "expo": "^54.0.0",
    "expo-asset": "~12.0.7",
    "expo-audio": "~1.1.1",
    "expo-file-system": "~19.0.11",
    "expo-gl": "~16.0.6",
    "llama.rn": "^0.11.0",
    "piper-tts": "file:./plugins/piper-tts",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.4",
    "react-native-bootsplash": "^7.1.0",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-quick-sqlite": "^8.2.0",
    "react-native-reanimated": "^3.19.5",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-svg": "^15.15.3",
    "react-native-tts": "^4.1.1",
    "react-native-worklets-core": "^1.6.3",
    "storybook": "^10.2.19",
    "three": "^0.162.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "19.1.2",
    "@react-native-community/cli-platform-android": "19.1.2",
    "@react-native-community/cli-platform-ios": "19.1.2",
    "@react-native/babel-preset": "0.81.4",
    "@react-native/eslint-config": "0.81.4",
    "@react-native/metro-config": "0.81.4",
    "@react-native/typescript-config": "0.81.4",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.1.0",
    "@types/react-test-renderer": "^19.1.0",
    "@types/three": "^0.162.0",
    "babel-plugin-inline-dotenv": "^1.7.0",
    "dotenv-cli": "^7.4.2",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "19.1.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  },
  "pnpm": {
    "overrides": {
      "three": "0.162.0"
    }
  },
  "resolutions": {
    "three": "0.162.0"
  }
}
